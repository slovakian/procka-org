---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Jason Procka"
	description="Hobbyist web developer based in North Dakota."
>
	<header class="flex flex-col gap-6">
		<h1 class="text-xl font-medium tracking-tight text-foreground md:text-2xl">
			Jason Procka
		</h1>
		<p class="text-muted-foreground leading-relaxed">
			I’m a hobbyist web developer in North Dakota. I like small, well-made sites and
			quiet corners of the internet.
		</p>
		<p class="text-muted-foreground leading-relaxed">
			This place is mostly a notebook in public: <a
				href="/projects"
				class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
				>projects</a
			>, longer <a
				href="/writing"
				class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
				>essays</a
			>, a casual <a
				href="/blog"
				class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
				>blog</a
			>, and <a
				href="/utils"
				class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
				>utils</a
			>—snippets and things I’ve learned.
		</p>
	</header>

	<p class="select-none text-center text-muted-foreground/40 text-xs tracking-[0.35em]">
		··—··
	</p>
</BaseLayout>
