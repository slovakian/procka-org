---
import { ProjectsList } from "@/components/ProjectsList";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = [
	{
		title: "Notai",
		description: "A contemplative teachings web app.",
	},
	{
		title: "Retro live chat",
		description:
			"Currently unnamed. Transient rooms that obey the laws of thermodynamics.",
	},
] as const;
---

<BaseLayout
	title="Jason Procka"
	description="Hobbyist web developer from North Dakota."
>
	<header class="flex flex-col gap-6">
		<h1 class="text-xl font-medium tracking-tight text-foreground md:text-2xl">
			Jason Procka
		</h1>
		<p class="text-muted-foreground leading-relaxed">
			I'm a hobbyist web developer from North Dakota.
		</p>
	</header>

	<section class="flex flex-col gap-4" aria-labelledby="projects-heading">
		<h2
			id="projects-heading"
			class="text-sm font-medium tracking-tight text-foreground"
		>
			Projects
		</h2>
		<ProjectsList items={[...projects]} />
	</section>
</BaseLayout>
