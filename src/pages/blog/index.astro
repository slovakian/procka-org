---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Blog · Jason Procka" description="Writing about whatever interests me.">
	<header class="flex flex-col gap-2">
		<h1 class="text-lg font-medium text-foreground">Blog</h1>
		<p class="text-muted-foreground text-sm leading-relaxed">
			Shorter, informal posts. Heavier essays live under <a
				href="/writing"
				class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-foreground"
				>Writing</a
			>.
		</p>
	</header>

	<p class="rounded-lg border border-dashed border-border bg-muted/30 px-4 py-8 text-center text-muted-foreground text-sm">
		No posts yet.
	</p>
</BaseLayout>
