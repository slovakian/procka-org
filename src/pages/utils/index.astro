---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Utils · Jason Procka"
	description="TypeScript, React, and small tools worth sharing."
>
	<header class="flex flex-col gap-2">
		<h1 class="text-lg font-medium text-foreground">Utils</h1>
		<p class="text-muted-foreground text-sm leading-relaxed">
			Short write-ups and code I want to share—patterns, React bits, TypeScript tricks.
			Separate from the blog so it stays easy to scan.
		</p>
	</header>

	<p class="rounded-lg border border-dashed border-border bg-muted/30 px-4 py-8 text-center text-muted-foreground text-sm">
		Nothing published here yet.
	</p>
</BaseLayout>
