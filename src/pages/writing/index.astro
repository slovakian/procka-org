---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Writing · Jason Procka"
	description="Longer, more serious essays and pieces."
>
	<header class="flex flex-col gap-2">
		<h1 class="text-lg font-medium text-foreground">Writing</h1>
		<p class="text-muted-foreground text-sm leading-relaxed">
			Essays and longer work I want to keep separate from the casual blog. Nothing published
			here yet.
		</p>
	</header>

	<p
		class="rounded-lg border border-dashed border-border bg-muted/30 px-4 py-8 text-center text-muted-foreground text-sm"
	>
		No pieces yet.
	</p>
</BaseLayout>
